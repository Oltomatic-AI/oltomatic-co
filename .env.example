# ──────────────────────────────────────────────────────────────
# Oltomatic AI — environment variables
# Copy to .env.local for local dev, or add to Vercel project env.
# ──────────────────────────────────────────────────────────────

# Resend — required for contact/support forms to actually email you.
# Get key from https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Where to send internal notifications. Defaults to tech@oltomatic.ai.
INTAKE_NOTIFY_EMAIL=tech@oltomatic.ai

# Verified "from" address. Must be on a domain verified in Resend.
# Defaults to "Oltomatic <hello@oltomatic.ai>".
RESEND_FROM_ADDRESS="Oltomatic <hello@oltomatic.ai>"

# Optional: forward submissions to n8n as well. Leave unset to skip.
# CONTACT_WEBHOOK_URL=https://oltomaticai.app.n8n.cloud/webhook/xxx
